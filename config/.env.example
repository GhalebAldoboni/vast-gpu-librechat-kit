# Copy this to your LibreChat .env and fill in secrets before starting LibreChat.

HOST=127.0.0.1
PORT=3080
MONGO_URI=mongodb://127.0.0.1:27017/LibreChat

DOMAIN_CLIENT=http://127.0.0.1:3080
DOMAIN_SERVER=http://127.0.0.1:3080
CONFIG_PATH=/path/to/LibreChat/librechat.yaml
APP_TITLE=LibreChat GPU

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# LibreChat expects these to exist. For the local llama.cpp endpoint, dummy is fine.
OPENAI_API_KEY=dummy
OPENAI_MODERATION=false
ENDPOINTS=custom
VAST_GPU_API_KEY=dummy

# Local tunnel endpoint. Keep this unless you change the local SSH -L port.
VAST_GPU_BASE_URL=http://127.0.0.1:8080/v1

# Local SearXNG-compatible Bing RSS proxy.
SEARXNG_INSTANCE_URL=http://127.0.0.1:3090

# Generate fresh values for a new install:
# openssl rand -hex 32
JWT_SECRET=replace-with-random-hex
JWT_REFRESH_SECRET=replace-with-random-hex
CREDS_KEY=replace-with-random-hex
CREDS_IV=replace-with-random-hex
